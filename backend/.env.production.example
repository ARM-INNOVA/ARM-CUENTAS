# ARM CUENTAS - Configuración para Producción (RENDER)
# 
# IMPORTANTE: 
# - En Render, estas variables se definen en render.yaml
# - Este archivo es solo como referencia
# - NO subas valores reales a Git
# - Usar variables de entorno de Render en lugar de .env

# Base de datos - Será generada automáticamente por Render
# En render.yaml: fromDatabase: arm-cuentas-db, property: connectionString
DATABASE_URL=postgresql://armcuentas:password@db.render.internal:5432/arm_cuentas

# Seguridad - Se genera automáticamente en Render (generateValue: true)
# Debe ser una cadena larga y aleatoria, mínimo 32 caracteres
SECRET_KEY=your-secure-random-key-generated-by-render-min-32-chars

# Entorno
ENVIRONMENT=production

# Almacenamiento de facturas - Disco persistente en Render
UPLOAD_DIR=/var/data/uploads

# Modo debug - NUNCA activar en producción
DEBUG=False

# Python
PYTHONUNBUFFERED=1

# CORS - Agregar tu dominio después de desplegar
# En render.yaml: valor separado por comas
ALLOWED_ORIGINS=https://arm-cuentas.onrender.com,https://arm-cuentas-web.onrender.com,https://tu-dominio.com

# OCR para lecturas de PDFs
USE_OCR=True

# AWS S3 (Opcional para almacenamiento en la nube)
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=eu-west-1

# Logging
LOG_LEVEL=INFO

# HTTPS
# En Render se configura automáticamente
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
