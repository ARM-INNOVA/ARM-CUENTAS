# Variables de entorno para ARM CUENTAS

# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/arm_cuentas

# Seguridad
SECRET_KEY=tu-clave-super-secreta-cambiar-en-produccion
DEBUG=False

# Servidor
HOST=0.0.0.0
PORT=8000

# Almacenamiento
UPLOAD_DIR=uploads
USE_OCR=True

# AWS S3 (opcional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=eu-west-1
